{
  "name": "clawlet",
  "version": "0.1.0",
  "description": "Financial governance layer for autonomous AI agent payments — budget limits, audit trails, human-approval gates for x402",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "clawlet": "dist/cli.js"
  },
  "files": [
    "dist/",
    "dashboard/dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && cd dashboard && npm install && npm run build",
    "build:core": "tsc",
    "build:dashboard": "cd dashboard && npm install && npm run build",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dashboard": "node dist/api.js",
    "dev": "concurrently -n api,ui -c blue,magenta \"tsx src/api.ts\" \"cd dashboard && npx vite\"",
    "dev:api": "tsx src/api.ts",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "postinstall": "prisma generate"
  },
  "keywords": [
    "ai-agent",
    "wallet",
    "x402",
    "mcp",
    "usdc",
    "base",
    "erc-3009",
    "agent-economy",
    "governance",
    "spending-limits"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/clawletxyz/clawlet.git"
  },
  "homepage": "https://github.com/clawletxyz/clawlet",
  "bugs": {
    "url": "https://github.com/clawletxyz/clawlet/issues"
  },
  "author": "clawletxyz",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@coinbase/cdp-sdk": "^1.44.1",
    "@hono/node-server": "^1.19.9",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@prisma/adapter-better-sqlite3": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^17.3.1",
    "hono": "^4.12.0",
    "viem": "^2.23.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.13.4",
    "concurrently": "^9.2.1",
    "prisma": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
